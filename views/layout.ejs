<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'SSP' %> &mdash; SSP 3D Repository</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="main-header">
    <div class="header-brand">
      <a href="/home" class="brand-link">
        <span class="brand-icon">&#9670;</span> SSP 3D Repository
      </a>
    </div>
    <nav class="main-nav">
      <a href="/home" class="nav-link">Home</a>
      <a href="/about" class="nav-link">About</a>
      <a href="/contact" class="nav-link">Contact</a>
      <% if (user) { %>
        <a href="/models" class="nav-link">Models</a>
        <a href="/report" class="nav-link">Report</a>
        <% if (user.role === 'admin') { %>
          <a href="/users" class="nav-link">Users</a>
        <% } %>
      <% } %>
    </nav>
    <div class="header-auth">
      <% if (user) { %>
        <span class="user-badge"><%= user.username %> <span class="role-tag role-<%= user.role %>"><%= user.role %></span></span>
        <a href="/logout" class="btn btn-sm btn-outline">Logout</a>
      <% } else { %>
        <a href="/login" class="btn btn-sm btn-outline">Login</a>
        <a href="/register" class="btn btn-sm btn-primary-light">Register</a>
      <% } %>
    </div>
  </header>

  <% if (flash) { %>
    <div class="flash-message"><%= flash %></div>
  <% } %>

  <main class="main-content">
