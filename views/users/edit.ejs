<%- include('../layout') %>

<div class="card" style="max-width:560px;">
  <h1>Edit User</h1>

  <% if (error) { %>
    <div class="error-message mt-1"><%= error %></div>
  <% } %>

  <form method="post" action="/users/<%= userRecord.id %>" id="userEditForm" onsubmit="return validateUserEditForm();" class="mt-2">
    <div class="form-group">
      <label>Username <span class="required">*</span></label>
      <input type="text" name="username" id="e_username" class="form-control" value="<%= userRecord.username %>" required />
    </div>
    <div class="form-group">
      <label>Email <span class="required">*</span></label>
      <input type="email" name="email" id="e_email" class="form-control" value="<%= userRecord.email %>" required />
    </div>
    <div class="form-group">
      <label>Role <span class="required">*</span></label>
      <select name="role" id="e_role" class="form-control" required>
        <option value="user" <%= userRecord.role === 'user' ? 'selected' : '' %>>User</option>
        <option value="admin" <%= userRecord.role === 'admin' ? 'selected' : '' %>>Admin</option>
      </select>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/users" class="btn btn-outline-primary">Cancel</a>
    </div>
  </form>
</div>

<%- include('../footer') %>
