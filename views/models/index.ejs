<%- include('../layout') %>

<div class="card">
  <div class="card-header">
    <h1>3D Models</h1>
    <a href="/models/new" class="btn btn-primary">+ Add New Model</a>
  </div>

  <form method="get" action="/models" class="search-bar">
    <input type="text" name="search" class="form-control" placeholder="Search by ID, title, author, or category…" value="<%= search || '' %>" />
    <button type="submit" class="btn btn-primary">Search</button>
    <% if (search) { %>
      <a href="/models" class="btn btn-outline-primary">Reset</a>
    <% } %>
  </form>

  <% if (models.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">&#x1F4ED;</div>
      <p>No models found.</p>
      <a href="/models/new" class="btn btn-primary btn-sm">Add your first model</a>
    </div>
  <% } else { %>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Model ID</th>
            <th>Title</th>
            <th>Category</th>
            <th>Format</th>
            <th>Status</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% models.forEach(m => { %>
            <tr>
              <td><code><%= m.model_id %></code></td>
              <td><strong><%= m.title %></strong></td>
              <td><%= m.category %></td>
              <td><%= m.format %></td>
              <td><span class="badge badge-<%= m.visibility_status.toLowerCase() %>"><%= m.visibility_status %></span></td>
              <td><%= m.created_at %></td>
              <td>
                <div class="table-actions">
                  <a href="/models/<%= m.id %>" class="btn btn-sm btn-outline-primary">View</a>
                  <% if (user && (user.role === 'admin' || user.id === m.created_by)) { %>
                    <a href="/models/<%= m.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form method="post" action="/models/<%= m.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this model?');">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../footer') %>
