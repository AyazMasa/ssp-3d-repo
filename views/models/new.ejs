<%- include('../layout') %>

<div class="card" style="max-width:720px;">
  <h1>Add New Model</h1>

  <% if (error) { %>
    <div class="error-message mt-1"><%= error %></div>
  <% } %>

  <form method="post" action="/models/new" id="modelForm" onsubmit="return validateModelForm();" class="mt-2">
    <div class="form-row">
      <div class="form-group">
        <label>Model ID <span class="required">*</span></label>
        <input type="text" name="model_id" id="model_id" class="form-control" placeholder="e.g. MDL-0001" value="<%= old.model_id || '' %>" required />
      </div>
      <div class="form-group">
        <label>Title <span class="required">*</span></label>
        <input type="text" name="title" id="model_title" class="form-control" placeholder="Model title" value="<%= old.title || '' %>" required />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Author Name <span class="required">*</span></label>
        <input type="text" name="author_name" id="model_author" class="form-control" placeholder="Author name" value="<%= old.author_name || '' %>" required />
      </div>
      <div class="form-group">
        <label>Author Email <span class="required">*</span></label>
        <input type="email" name="author_email" id="model_email" class="form-control" placeholder="author@email.com" value="<%= old.author_email || '' %>" required />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Category <span class="required">*</span></label>
        <input type="text" name="category" id="model_category" class="form-control" placeholder="e.g. Architecture, Engineering" value="<%= old.category || '' %>" required />
      </div>
      <div class="form-group">
        <label>Format <span class="required">*</span></label>
        <input type="text" name="format" id="model_format" class="form-control" placeholder="e.g. OBJ, STL, FBX" value="<%= old.format || '' %>" required />
      </div>
    </div>

    <div class="form-group">
      <label>File Link <span class="required">*</span></label>
      <input type="text" name="file_link" id="model_link" class="form-control" placeholder="URL or file path" value="<%= old.file_link || '' %>" required />
    </div>

    <div class="form-group">
      <label>Visibility Status</label>
      <select name="visibility_status" class="form-control">
        <option value="Public" <%= (old.visibility_status === 'Public' || !old.visibility_status) ? 'selected' : '' %>>Public</option>
        <option value="Hidden" <%= old.visibility_status === 'Hidden' ? 'selected' : '' %>>Hidden</option>
      </select>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Model</button>
      <a href="/models" class="btn btn-outline-primary">Cancel</a>
    </div>
  </form>
</div>

<%- include('../footer') %>
