<%- include('../layout') %>

<%
  const fileLink = model.file_link || "";
  const ext = fileLink.split("?")[0].split(".").pop().toLowerCase();
  const isGlb = ext === "glb" || ext === "gltf";
  const isThreeJs = ext === "stl" || ext === "obj";
  const hasViewer = isGlb || isThreeJs;
%>

<div class="card" style="max-width:900px;">
  <div class="card-header">
    <h1>Model Details</h1>
    <div>
      <% if (user && (user.role === 'admin' || user.id === model.created_by)) { %>
        <a href="/models/<%= model.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
      <% } %>
      <a href="/models" class="btn btn-sm btn-outline-primary">Back to List</a>
    </div>
  </div>

  <% if (hasViewer) { %>
    <div class="viewer-container" style="width:100%;height:400px;background:#f0f2f5;border-radius:8px;margin-bottom:1.5rem;overflow:hidden;position:relative;">
      <% if (isGlb) { %>
        <!-- Google model-viewer for GLB / GLTF -->
        <model-viewer
          src="<%= model.file_link %>"
          alt="<%= model.title %>"
          auto-rotate
          camera-controls
          shadow-intensity="1"
          style="width:100%;height:100%;"
          poster=""
        >
          <div slot="poster" style="display:flex;align-items:center;justify-content:center;height:100%;color:#888;">Loading 3D model…</div>
        </model-viewer>
      <% } else { %>
        <!-- Three.js canvas for STL / OBJ -->
        <canvas id="viewer3d" style="width:100%;height:100%;display:block;"></canvas>
      <% } %>
    </div>
  <% } %>

  <div class="detail-grid">
    <div class="detail-label">Model ID</div>
    <div class="detail-value"><code><%= model.model_id %></code></div>

    <div class="detail-label">Title</div>
    <div class="detail-value"><%= model.title %></div>

    <div class="detail-label">Author</div>
    <div class="detail-value"><%= model.author_name %></div>

    <div class="detail-label">Email</div>
    <div class="detail-value"><a href="mailto:<%= model.author_email %>"><%= model.author_email %></a></div>

    <div class="detail-label">Category</div>
    <div class="detail-value"><%= model.category %></div>

    <div class="detail-label">Format</div>
    <div class="detail-value"><%= model.format %></div>

    <div class="detail-label">File Link</div>
    <div class="detail-value">
      <% const safeLink = (model.file_link || '').match(/^https?:\/\//) ? model.file_link : '#'; %>
      <a href="<%= safeLink %>" target="_blank" rel="noopener noreferrer"><%= model.file_link %></a>
    </div>

    <div class="detail-label">Status</div>
    <div class="detail-value"><span class="badge badge-<%= model.visibility_status.toLowerCase() %>"><%= model.visibility_status %></span></div>

    <div class="detail-label">Created</div>
    <div class="detail-value"><%= model.created_at %></div>

    <% if (model.owner_name) { %>
      <div class="detail-label">Added By</div>
      <div class="detail-value"><%= model.owner_name %></div>
    <% } %>
  </div>
</div>

<% if (isGlb) { %>
  <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
<% } %>
<% if (isThreeJs) { %>
  <script>window.__modelFileLink = <%- JSON.stringify(model.file_link) %>;</script>
  <script src="/js/viewer3d.js"></script>
<% } %>

<%- include('../footer') %>
