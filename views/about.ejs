<%- include('layout') %>

<div class="card">
  <h1>About This Portal</h1>
  <p class="mt-1" style="color:var(--text-secondary); max-width:720px; line-height:1.8;">
    The Smart Student Portal (SSP) &mdash; 3D Schematics Repository is a full-stack web application
    built to demonstrate modern internet technologies. It serves as a centralized hub for managing
    3D model records within a university department setting.
  </p>
</div>

<div class="card">
  <h2>System Features</h2>
  <div class="feature-grid mt-2">
    <div class="feature-card">
      <h3>&#x1F310; HTML5 &amp; CSS3</h3>
      <p>Structured, semantic markup with responsive, modern styling.</p>
    </div>
    <div class="feature-card">
      <h3>&#x26A1; JavaScript</h3>
      <p>Client-side form validation and interactive DOM manipulation.</p>
    </div>
    <div class="feature-card">
      <h3>&#x1F4C4; XML &amp; XSLT</h3>
      <p>Data export to XML format with XSLT-based HTML transformation.</p>
    </div>
    <div class="feature-card">
      <h3>&#x1F5A5;&#xFE0F; Node.js + Express</h3>
      <p>Backend framework with routing, middleware, and template rendering.</p>
    </div>
    <div class="feature-card">
      <h3>&#x1F5C4;&#xFE0F; SQLite Database</h3>
      <p>Relational database for persistent data storage and CRUD operations.</p>
    </div>
    <div class="feature-card">
      <h3>&#x1F510; Session Management</h3>
      <p>Secure login/logout with role-based access control (admin/user).</p>
    </div>
  </div>
</div>

<div class="card">
  <h2>Technologies Used</h2>
  <div class="table-wrapper mt-2">
    <table>
      <thead>
        <tr><th>Technology</th><th>Purpose</th></tr>
      </thead>
      <tbody>
        <tr><td>HTML5</td><td>Page structure and semantic markup</td></tr>
        <tr><td>CSS3</td><td>Styling, layout, and responsive design</td></tr>
        <tr><td>JavaScript</td><td>Client-side validation and interactivity</td></tr>
        <tr><td>Node.js + Express</td><td>Backend server and routing</td></tr>
        <tr><td>EJS</td><td>Template engine for dynamic pages</td></tr>
        <tr><td>SQLite</td><td>Database storage</td></tr>
        <tr><td>XML + XSLT (Saxon-JS)</td><td>Data export and transformation</td></tr>
        <tr><td>bcryptjs</td><td>Password hashing</td></tr>
        <tr><td>express-session</td><td>Session management</td></tr>
      </tbody>
    </table>
  </div>
</div>

<%- include('footer') %>
