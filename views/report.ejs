<%- include('layout') %>

<div class="card">
  <div class="card-header">
    <h1>Models Report</h1>
    <div>
      <a href="/report/html" target="_blank" class="btn btn-primary btn-sm">Open Full Report</a>
      <a href="/report/xml" target="_blank" class="btn btn-outline-primary btn-sm">View Raw XML</a>
    </div>
  </div>
  <p style="color:var(--text-secondary); margin-bottom:1.5rem;">
    This report is generated by exporting model data to XML and transforming it into an HTML report via XSLT.
  </p>
  <div style="border:1px solid var(--border); border-radius:var(--radius); overflow:hidden;">
    <iframe src="/report/html" style="width:100%; height:600px; border:none;"></iframe>
  </div>
</div>

<%- include('footer') %>
