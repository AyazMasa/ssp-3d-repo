<%- include('layout') %>

<div class="card" style="max-width:640px;">
  <h1>Contact Us</h1>
  <p class="mt-1 mb-3" style="color:var(--text-secondary);">Have a question or feedback? Send us a message using the form below.</p>

  <div id="contact-success" class="flash-message" style="display:none;">Your message has been sent successfully! We'll get back to you soon.</div>
  <div id="contact-error" class="error-message" style="display:none;">Something went wrong. Please try again later.</div>

  <form id="contactForm" class="mt-1">
    <div class="form-group">
      <label>Your Name <span class="required">*</span></label>
      <input type="text" name="name" class="form-control" id="contact_name" placeholder="John Doe" required maxlength="100" />
    </div>
    <div class="form-group">
      <label>Your Email <span class="required">*</span></label>
      <input type="email" name="email" class="form-control" id="contact_email" placeholder="john@example.com" required maxlength="150" />
    </div>
    <div class="form-group">
      <label>Subject</label>
      <input type="text" name="subject" class="form-control" id="contact_subject" placeholder="General inquiry" maxlength="200" />
    </div>
    <div class="form-group">
      <label>Message <span class="required">*</span></label>
      <textarea name="message" class="form-control" id="contact_message" placeholder="Write your message here..." required maxlength="2000"></textarea>
    </div>
    <input type="hidden" name="_subject" value="New SSP Contact Form Submission" />
    <div class="form-actions">
      <button type="submit" class="btn btn-primary" id="contact-btn">Send Message</button>
    </div>
  </form>
</div>

<script>
document.getElementById('contactForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = document.getElementById('contact-btn');
  var successEl = document.getElementById('contact-success');
  var errorEl = document.getElementById('contact-error');
  successEl.style.display = 'none';
  errorEl.style.display = 'none';
  btn.disabled = true;
  btn.textContent = 'Sending…';

  try {
    var resp = await fetch('https://formspree.io/f/xlgwqggz', {
      method: 'POST',
      body: new FormData(this),
      headers: { 'Accept': 'application/json' }
    });
    if (resp.ok) {
      successEl.style.display = 'block';
      this.reset();
    } else {
      errorEl.style.display = 'block';
    }
  } catch (err) {
    errorEl.style.display = 'block';
  }
  btn.disabled = false;
  btn.textContent = 'Send Message';
});
</script>

<%- include('footer') %>
